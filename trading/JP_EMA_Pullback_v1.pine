// ══════════════════════════════════════════════════════════════════════════════
// JP — EMA Pullback Strategy v1.0
// Auteur   : Assistant JP
// Marché   : ETH/USDT · SOL/USDT · CAC40
// TF Entry : 15m · 30m · 1H (à choisir dans TradingView)
// TF Trend : 4H (filtre de tendance)
// Objectif : Win Rate > 65% | Max Drawdown < 13%
// ══════════════════════════════════════════════════════════════════════════════

//@version=5
strategy("JP — EMA Pullback v1.0",
     shorttitle            = "JP-EPS v1",
     overlay               = true,
     initial_capital       = 10000,
     currency              = currency.USD,
     default_qty_type      = strategy.cash,
     default_qty_value     = 100,
     commission_type       = strategy.commission.percent,
     commission_value      = 0.1,
     slippage              = 2,
     pyramiding            = 0,
     calc_on_order_fills   = false,
     process_orders_on_close = false)

// ══════════════════════════════════════════════════════════════════════════════
//  INPUTS
// ══════════════════════════════════════════════════════════════════════════════

// ─ Gestion du risque ─────────────────────────────────────────────────────────
var GRP_RISK = "💰 Gestion du Risque"
i_risk_pct    = input.float(1.0,  "Risque par trade (%)",     0.1,  5.0, 0.1, group=GRP_RISK, tooltip="% du capital risqué par trade. Ne jamais dépasser 2%.")
i_rr_tp1      = input.float(1.5,  "R:R au TP1",               1.0,  5.0, 0.1, group=GRP_RISK)
i_rr_tp2      = input.float(2.5,  "R:R au TP2",               1.0, 10.0, 0.1, group=GRP_RISK)
i_tp1_pct     = input.int(50,     "% position clôturée à TP1", 10,   90,  5,   group=GRP_RISK)

// ─ EMAs ──────────────────────────────────────────────────────────────────────
var GRP_EMA = "📈 EMAs"
i_ema_fast = input.int(21,  "EMA Rapide (pullback)",   5,   group=GRP_EMA)
i_ema_mid  = input.int(50,  "EMA Médiane (structure)", 10,  group=GRP_EMA)
i_ema_slow = input.int(200, "EMA Lente (tendance)",    50,  group=GRP_EMA)

// ─ RSI ───────────────────────────────────────────────────────────────────────
var GRP_RSI = "📊 RSI"
i_rsi_len = input.int(14, "Longueur RSI", group=GRP_RSI)
i_rsi_min = input.int(40, "Zone neutre min (40)",    20, 49, group=GRP_RSI)
i_rsi_max = input.int(60, "Zone neutre max (60)",    51, 80, group=GRP_RSI)

// ─ ATR ───────────────────────────────────────────────────────────────────────
var GRP_ATR = "⚙️ Stop (ATR)"
i_atr_len  = input.int(14,   "Longueur ATR",                 group=GRP_ATR)
i_atr_mult = input.float(1.2,"Multiplicateur ATR → Stop", 0.5, 3.0, 0.1, group=GRP_ATR,
     tooltip="Stop = swing low/high ± ATR×mult. 1.2 = stop légèrement éloigné du bruit.")

// ─ Volume ────────────────────────────────────────────────────────────────────
var GRP_VOL = "📊 Volume"
i_vol_len = input.int(20, "Longueur MA Volume", group=GRP_VOL)

// ─ Multi-Timeframe ───────────────────────────────────────────────────────────
var GRP_TF = "🗺️ Multi-Timeframe"
i_tf_trend = input.timeframe("240", "TF Tendance (défaut 4H)", group=GRP_TF,
     tooltip="240 = 4H | 60 = 1H | D = Daily. Doit être SUPÉRIEUR au TF du graphique.")

// ─ LuxAlgo (optionnel) ───────────────────────────────────────────────────────
var GRP_LUX = "🔮 LuxAlgo — Filtre optionnel"
i_use_lux    = input.bool(false,  "Activer filtre LuxAlgo",                   group=GRP_LUX,
     tooltip="Si activé, connecte le plot LuxAlgo à la source ci-dessous.")
i_lux_src    = input.source(close,"↳ Source : connecte ici le plot LuxAlgo",  group=GRP_LUX,
     tooltip="Exemples : LuxAlgo 'Signal+' histogram, 'Oscillator Matrix' line, etc.")
i_lux_thresh = input.float(0.0,   "↳ Seuil Long (>X) / Short (<-X)",  group=GRP_LUX)

// ─ Affichage ─────────────────────────────────────────────────────────────────
var GRP_DISP = "🎨 Affichage"
i_show_bg   = input.bool(true, "Fond coloré selon tendance 4H", group=GRP_DISP)
i_show_emas = input.bool(true, "Afficher les 3 EMAs",           group=GRP_DISP)
i_show_sl   = input.bool(true, "Afficher lignes SL/TP",         group=GRP_DISP)

// ══════════════════════════════════════════════════════════════════════════════
//  INDICATEURS — Timeframe courant
// ══════════════════════════════════════════════════════════════════════════════
ema21  = ta.ema(close, i_ema_fast)
ema50  = ta.ema(close, i_ema_mid)
ema200 = ta.ema(close, i_ema_slow)
rsi    = ta.rsi(close, i_rsi_len)
atr    = ta.atr(i_atr_len)
vol_ma = ta.sma(volume, i_vol_len)

// ══════════════════════════════════════════════════════════════════════════════
//  TENDANCE — Timeframe supérieur (4H)
// ══════════════════════════════════════════════════════════════════════════════
[c_htf, ema50_htf, ema200_htf] = request.security(
     syminfo.tickerid,
     i_tf_trend,
     [close, ta.ema(close, i_ema_mid), ta.ema(close, i_ema_slow)],
     lookahead = barmerge.lookahead_off)

// Tendance haussière 4H : prix > EMA200 ET EMA50 > EMA200
bull_4h = c_htf > ema200_htf and ema50_htf > ema200_htf
// Tendance baissière 4H : prix < EMA200 ET EMA50 < EMA200
bear_4h = c_htf < ema200_htf and ema50_htf < ema200_htf

// ══════════════════════════════════════════════════════════════════════════════
//  CONDITIONS D'ENTRÉE
// ══════════════════════════════════════════════════════════════════════════════

// Structure locale alignée avec la tendance
ema_bull_local = ema21 > ema50   // EMA21 au-dessus de EMA50
ema_bear_local = ema21 < ema50   // EMA21 en-dessous de EMA50

// Pullback sur EMA21 :
//   LONG  → le low a touché l'EMA21, close revient au-dessus, bougie verte
//   SHORT → le high a touché l'EMA21, close repasse en-dessous, bougie rouge
pullback_long  = low  <= ema21 * 1.003 and close > ema21 and close >= open
pullback_short = high >= ema21 * 0.997 and close < ema21 and close <= open

// RSI en zone neutre (ni suracheté ni survendu → pullback sain)
rsi_ok = rsi >= i_rsi_min and rsi <= i_rsi_max

// Volume au-dessus de la moyenne
vol_ok = volume > vol_ma

// Filtre LuxAlgo (optionnel)
lux_long  = not i_use_lux or i_lux_src >  i_lux_thresh
lux_short = not i_use_lux or i_lux_src < -i_lux_thresh

// Pas déjà en position
flat = strategy.position_size == 0

// ─── SIGNAUX FINAUX ───────────────────────────────────────────────────────────
long_signal  = bull_4h and ema_bull_local and pullback_long  and rsi_ok and vol_ok and lux_long  and flat
short_signal = bear_4h and ema_bear_local and pullback_short and rsi_ok and vol_ok and lux_short and flat

// ══════════════════════════════════════════════════════════════════════════════
//  CALCUL SL / TP (capturés au signal)
// ══════════════════════════════════════════════════════════════════════════════
var float entry_p = na
var float sl_p    = na
var float tp1_p   = na
var float tp2_p   = na

if long_signal
    entry_p := close
    sl_p    := math.min(low, ema21) - atr * i_atr_mult
    float r  = entry_p - sl_p
    tp1_p   := entry_p + r * i_rr_tp1
    tp2_p   := entry_p + r * i_rr_tp2

if short_signal
    entry_p := close
    sl_p    := math.max(high, ema21) + atr * i_atr_mult
    float r  = sl_p - entry_p
    tp1_p   := entry_p - r * i_rr_tp1
    tp2_p   := entry_p - r * i_rr_tp2

// ══════════════════════════════════════════════════════════════════════════════
//  POSITION SIZING — 1% de risque (calcul dynamique)
// ══════════════════════════════════════════════════════════════════════════════
// Quantité = (Capital × Risque%) / Distance au SL
float risk_$   = strategy.equity * (i_risk_pct / 100.0)
float sl_dist  = long_signal  ? math.abs(close - (math.min(low, ema21) - atr * i_atr_mult))
               : short_signal ? math.abs((math.max(high, ema21) + atr * i_atr_mult) - close)
               : na
float qty      = sl_dist > 0 ? risk_$ / sl_dist : na

// ══════════════════════════════════════════════════════════════════════════════
//  ORDRES
// ══════════════════════════════════════════════════════════════════════════════
if long_signal and not na(qty)
    strategy.entry("Long", strategy.long, qty=qty)
    // TP1 : ferme i_tp1_pct % de la position au R:R 1.5 avec SL en garde
    strategy.exit("TP1 Long",  "Long", qty_percent=i_tp1_pct, limit=tp1_p, stop=sl_p)
    // TP2 : ferme le reste au R:R 2.5 avec SL en garde
    strategy.exit("TP2 Long",  "Long", qty_percent=100,        limit=tp2_p, stop=sl_p)

if short_signal and not na(qty)
    strategy.entry("Short", strategy.short, qty=qty)
    strategy.exit("TP1 Short", "Short", qty_percent=i_tp1_pct, limit=tp1_p, stop=sl_p)
    strategy.exit("TP2 Short", "Short", qty_percent=100,        limit=tp2_p, stop=sl_p)

// ══════════════════════════════════════════════════════════════════════════════
//  VISUALISATION
// ══════════════════════════════════════════════════════════════════════════════

// Fond coloré tendance 4H
bgcolor(i_show_bg and bull_4h ? color.new(color.green, 94) :
        i_show_bg and bear_4h ? color.new(color.red,   94) : na,
        title="Fond tendance 4H")

// EMAs
plot(i_show_emas ? ema21  : na, "EMA 21",  color.new(color.lime,   0), 1)
plot(i_show_emas ? ema50  : na, "EMA 50",  color.new(color.orange, 0), 1)
plot(i_show_emas ? ema200 : na, "EMA 200", color.new(color.red,    0), 2)

// Signaux
plotshape(long_signal,  "🟢 LONG",  shape.triangleup,   location.belowbar, color.new(color.lime, 0), size=size.normal)
plotshape(short_signal, "🔴 SHORT", shape.triangledown, location.abovebar, color.new(color.red,  0), size=size.normal)

// Labels SL / TP1 / TP2 au signal
if long_signal or short_signal
    if i_show_sl
        label.new(bar_index, sl_p,  "🛑 SL\n"  + str.tostring(sl_p,  format.mintick),
             color=color.new(color.red,   75), textcolor=color.white,
             style=label.style_label_right, size=size.tiny)
        label.new(bar_index, tp1_p, "🎯 TP1\n" + str.tostring(tp1_p, format.mintick),
             color=color.new(color.green, 75), textcolor=color.white,
             style=label.style_label_right, size=size.tiny)
        label.new(bar_index, tp2_p, "🚀 TP2\n" + str.tostring(tp2_p, format.mintick),
             color=color.new(color.blue,  75), textcolor=color.white,
             style=label.style_label_right, size=size.tiny)

// ══════════════════════════════════════════════════════════════════════════════
//  TABLE D'INFO (coin bas droit)
// ══════════════════════════════════════════════════════════════════════════════
var table info = table.new(position.bottom_right, 2, 5,
     bgcolor=color.new(color.black, 70), border_color=color.new(color.gray, 60), border_width=1)

if barstate.islast
    table.cell(info, 0, 0, "📊 JP-EPS v1",  text_color=color.white,  text_size=size.small, bgcolor=color.new(color.navy, 40))
    table.cell(info, 1, 0, syminfo.ticker,   text_color=color.yellow, text_size=size.small, bgcolor=color.new(color.navy, 40))

    table.cell(info, 0, 1, "Tendance 4H",   text_color=color.gray,  text_size=size.tiny)
    table.cell(info, 1, 1, bull_4h ? "🟢 BULL" : bear_4h ? "🔴 BEAR" : "⚪ FLAT",
         text_color=bull_4h ? color.lime : bear_4h ? color.red : color.gray, text_size=size.tiny)

    table.cell(info, 0, 2, "RSI",           text_color=color.gray,  text_size=size.tiny)
    table.cell(info, 1, 2, str.tostring(math.round(rsi, 1)),
         text_color=rsi_ok ? color.green : color.orange, text_size=size.tiny)

    table.cell(info, 0, 3, "Volume",        text_color=color.gray,  text_size=size.tiny)
    table.cell(info, 1, 3, vol_ok ? "✅ OK" : "⚠️ Faible",
         text_color=vol_ok ? color.green : color.orange, text_size=size.tiny)

    table.cell(info, 0, 4, "Risque/trade",  text_color=color.gray,  text_size=size.tiny)
    table.cell(info, 1, 4, str.tostring(i_risk_pct) + "%",
         text_color=color.white, text_size=size.tiny)

// ══════════════════════════════════════════════════════════════════════════════
//  ALERTES TradingView
// ══════════════════════════════════════════════════════════════════════════════
alertcondition(long_signal,
     title   = "🟢 JP — Signal LONG",
     message = "{{ticker}} {{interval}} | LONG ✅\nClose : {{close}}\nSL : sous le dernier swing low − ATR\nR:R cible : 1.5 → 2.5")

alertcondition(short_signal,
     title   = "🔴 JP — Signal SHORT",
     message = "{{ticker}} {{interval}} | SHORT ✅\nClose : {{close}}\nSL : au-dessus du dernier swing high + ATR\nR:R cible : 1.5 → 2.5")
