//@version=5
strategy("JP EMA Pullback v3", overlay=true, initial_capital=10000, default_qty_type=strategy.cash, default_qty_value=100, commission_type=strategy.commission.percent, commission_value=0.1, slippage=2, pyramiding=0)

// ── INPUTS ────────────────────────────────────────────────────────────────────
i_risk_pct   = input.float(1.0,  "Risque par trade pct",  minval=0.5,  maxval=2.0,  step=0.5,  group="Risque")
i_tp1_pct    = input.int(50,     "Pct position ferme TP1",minval=25,   maxval=75,   step=25,   group="Risque")
i_ema_fast   = input.int(21,     "EMA Rapide",            minval=13,   maxval=34,   step=3,    group="EMAs")
i_ema_mid    = input.int(50,     "EMA Mediane",           minval=40,   maxval=70,   step=5,    group="EMAs")
i_ema_slow   = input.int(200,    "EMA Lente",             minval=100,  maxval=200,  step=10,   group="EMAs")
i_rsi_len    = input.int(14,     "RSI Longueur",                                              group="RSI")
i_rsi_min    = input.int(40,     "RSI zone min",          minval=35,   maxval=45,   step=5,    group="RSI")
i_rsi_max    = input.int(60,     "RSI zone max",          minval=55,   maxval=65,   step=5,    group="RSI")
i_atr_len    = input.int(14,     "ATR Longueur",                                              group="Stop ATR")
i_atr_mult   = input.float(1.2,  "Mult ATR Stop",         minval=0.8,  maxval=2.0,  step=0.2,  group="Stop ATR")
i_rr_tp1     = input.float(1.5,  "RR TP1",                minval=1.2,  maxval=2.0,  step=0.2,  group="Take Profits")
i_rr_tp2     = input.float(2.5,  "RR TP2",                minval=2.0,  maxval=3.5,  step=0.25, group="Take Profits")
i_vol_len    = input.int(20,     "Volume MA longueur",    minval=10,   maxval=30,   step=5,    group="Volume")
i_tf_trend   = input.timeframe("240", "TF Tendance 4H",                                       group="MultiTF")
i_use_lux    = input.bool(false, "Activer filtre LuxAlgo",                                     group="LuxAlgo")
i_lux_src    = input.source(close, "Source LuxAlgo",                                           group="LuxAlgo")
i_lux_thresh = input.float(0.0,  "Seuil LuxAlgo",                                             group="LuxAlgo")

// ── INDICATEURS ───────────────────────────────────────────────────────────────
ema21  = ta.ema(close, i_ema_fast)
ema50  = ta.ema(close, i_ema_mid)
ema200 = ta.ema(close, i_ema_slow)
rsi    = ta.rsi(close, i_rsi_len)
atr    = ta.atr(i_atr_len)
vol_ma = ta.sma(volume, i_vol_len)

// ── TENDANCE 4H ───────────────────────────────────────────────────────────────
c_htf      = request.security(syminfo.tickerid, i_tf_trend, close, lookahead=barmerge.lookahead_off)
ema50_htf  = request.security(syminfo.tickerid, i_tf_trend, ta.ema(close, i_ema_mid), lookahead=barmerge.lookahead_off)
ema200_htf = request.security(syminfo.tickerid, i_tf_trend, ta.ema(close, i_ema_slow), lookahead=barmerge.lookahead_off)

bull_4h = c_htf > ema200_htf and ema50_htf > ema200_htf
bear_4h = c_htf < ema200_htf and ema50_htf < ema200_htf

// ── CONDITIONS ────────────────────────────────────────────────────────────────
ema_bull  = ema21 > ema50
ema_bear  = ema21 < ema50
pb_long   = low  <= ema21 * 1.003 and close > ema21 and close >= open
pb_short  = high >= ema21 * 0.997 and close < ema21 and close <= open
rsi_ok    = rsi >= i_rsi_min and rsi <= i_rsi_max
vol_ok    = volume > vol_ma
flat      = strategy.position_size == 0
lux_long  = not i_use_lux or i_lux_src > i_lux_thresh
lux_short = not i_use_lux or i_lux_src < -i_lux_thresh

lng = bull_4h and ema_bull and pb_long  and rsi_ok and vol_ok and lux_long  and flat
sht = bear_4h and ema_bear and pb_short and rsi_ok and vol_ok and lux_short and flat

// ── SL / TP ───────────────────────────────────────────────────────────────────
var float sl_p  = na
var float tp1_p = na
var float tp2_p = na

if lng
    sl_p  := math.min(low, ema21) - atr * i_atr_mult
    float r = close - sl_p
    tp1_p  := close + r * i_rr_tp1
    tp2_p  := close + r * i_rr_tp2

if sht
    sl_p  := math.max(high, ema21) + atr * i_atr_mult
    float r = sl_p - close
    tp1_p  := close - r * i_rr_tp1
    tp2_p  := close - r * i_rr_tp2

// ── POSITION SIZING ───────────────────────────────────────────────────────────
var float qty = na

if lng
    float dist = math.abs(close - (math.min(low, ema21) - atr * i_atr_mult))
    if dist > 0
        qty := strategy.equity * i_risk_pct / 100.0 / dist

if sht
    float dist = math.abs((math.max(high, ema21) + atr * i_atr_mult) - close)
    if dist > 0
        qty := strategy.equity * i_risk_pct / 100.0 / dist

// ── ORDRES ────────────────────────────────────────────────────────────────────
if lng and not na(qty)
    strategy.entry("Long", strategy.long, qty=qty)
    strategy.exit("TP1 L", "Long", qty_percent=i_tp1_pct, limit=tp1_p, stop=sl_p)
    strategy.exit("TP2 L", "Long", qty_percent=100,        limit=tp2_p, stop=sl_p)

if sht and not na(qty)
    strategy.entry("Short", strategy.short, qty=qty)
    strategy.exit("TP1 S", "Short", qty_percent=i_tp1_pct, limit=tp1_p, stop=sl_p)
    strategy.exit("TP2 S", "Short", qty_percent=100,        limit=tp2_p, stop=sl_p)

// ── VISUELS ───────────────────────────────────────────────────────────────────
bgcolor(bull_4h ? color.new(color.green, 94) : bear_4h ? color.new(color.red, 94) : na, title="Fond 4H")
plot(ema21,  "EMA 21",  color.new(color.lime,   0), 1)
plot(ema50,  "EMA 50",  color.new(color.orange, 0), 1)
plot(ema200, "EMA 200", color.new(color.red,    0), 2)
plotshape(lng, "LONG",  shape.triangleup,   location.belowbar, color.new(color.lime, 0), size=size.normal)
plotshape(sht, "SHORT", shape.triangledown, location.abovebar, color.new(color.red,  0), size=size.normal)

// ── ALERTES ───────────────────────────────────────────────────────────────────
alertcondition(lng, "JP LONG",  "{{ticker}} {{interval}} LONG  | Close: {{close}}")
alertcondition(sht, "JP SHORT", "{{ticker}} {{interval}} SHORT | Close: {{close}}")
