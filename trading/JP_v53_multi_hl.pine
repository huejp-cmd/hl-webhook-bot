//@version=5
// ══════════════════════════════════════════════════════════════════════════════
//  JP v5.3 — Multi-Symbol Hyperliquid 30M
//  Calculs directs sur les barres du chart (30M)
//  Exchange : Hyperliquid Perpetuals (commission 0.07% round-trip)
//
//  UTILISATION :
//    Chart 1 : SOLUSDT.P 30M  — creer une alerte webhook
//    Chart 2 : ETHUSDT.P 30M  — creer une alerte webhook
//    Message alerte : {{alert.message}}
//    Webhook URL    : http://TON_IP:8080/webhook?token=jp_bot_secret_2026
// ══════════════════════════════════════════════════════════════════════════════
strategy("JP v5.3 - Multi-Symbol Hyperliquid 30M",
 overlay=true,
 default_qty_type=strategy.cash,
 commission_type=strategy.commission.percent,
 commission_value=0.07,
 pyramiding=1,
 initial_capital=500,
 calc_on_every_tick=false)

// ——————— PARAMETRES ———————
useFixedRange  = input.bool(false,  "Plage Fixe (sinon 1xATR)")
fixedRangeSize = input.float(1.2,   "Plage Fixe ($)", step=0.1, minval=0.1)
atrLength      = input.int(10,      "ATR Length")
adxLength      = input.int(14,      "ADX Length")
bbLength       = input.int(20,      "BB Length")
bbMult         = input.float(2.0,   "BB Mult")
rsiLength      = input.int(100,     "RSI Length")
volFilter      = input.bool(true,   "Volume Filter")
volMult        = input.float(1.4,   "Volume Threshold (x SMA)", step=0.1)
riskPerc       = input.float(2.0,   "Risk per trade (%)", step=0.1) / 100
maxDD          = input.float(13.0,  "Max Drawdown Alert (%)") / 100
vpK            = input.float(0.75,  "VAH/VAL offset (xATR)", step=0.05)
showStats      = input.bool(true,   "Afficher tableau perfs")
showParams     = input.bool(true,   "Afficher tableau parametres")
leverage       = input.float(2.0,   "Leverage", minval=1.0, step=0.5)
startCapital   = input.float(500.0, "Capital alloue ($)", minval=100, step=100)
slCapPct       = input.float(5.0,   "SL max (% du capital)", minval=1.0, maxval=20.0, step=0.5) / 100

stepCapital = startCapital

// ══════════════════════════════════════════════════════════════════════════════
//  FONCTIONS GLOBALES
// ══════════════════════════════════════════════════════════════════════════════
hullMa(src, length) =>
    n2      = math.floor(length / 2)
    sqrtLen = math.floor(math.sqrt(length))
    wma1    = ta.wma(src, n2)
    wma2    = ta.wma(src, length)
    ta.wma(2 * wma1 - wma2, sqrtLen)

// ══════════════════════════════════════════════════════════════════════════════
//  CALCULS PRINCIPAUX (sur barres du chart)
// ══════════════════════════════════════════════════════════════════════════════

// --- ATR ---
atr = ta.atr(atrLength)

// --- RSI / Volume ---
rsi    = ta.rsi(close, rsiLength)
volSma = ta.sma(volume, 20)
volUp  = volume > volSma * volMult

// --- HMA ---
ma20 = hullMa(close, 20)
ma50 = hullMa(close, 50)

// --- VWAP / VAH / VAL ---
cumVol = ta.cum(volume)
cumPV  = ta.cum(((high + low + close) / 3) * volume)
vwap_  = cumPV / nz(cumVol, 1)
vah    = ta.highest(vwap_ + vpK * atr, 24)
val    = ta.lowest( vwap_ - vpK * atr, 24)
poc    = vwap_

// --- DMI / ADX ---
[diplus, diminus, adx] = ta.dmi(adxLength, adxLength)

// --- Volatilite / InRange ---
var float[] volWin = array.new_float()
curVol = ta.stdev(math.log(high / low), 100)
array.push(volWin, curVol)
if array.size(volWin) > 100
    array.shift(volWin)
sorted = array.copy(volWin)
array.sort(sorted, order.ascending)
idx25  = math.round((array.size(sorted) - 1) * 0.25)
vol25  = array.get(sorted, math.min(idx25, array.size(sorted) - 1))

btcH   = request.security("BINANCE:BTCUSDT", "60", high)
btcL   = request.security("BINANCE:BTCUSDT", "60", low)
btcC   = request.security("BINANCE:BTCUSDT", "60", close[1])
btcRng = (btcH - btcL) / nz(btcC, 1)

inRng = adx < 20 and curVol < vol25 and btcRng < 0.01

// --- Regimes ---
basis       = ta.sma(close, bbLength)
dev         = bbMult * ta.stdev(close, bbLength)
upperBB     = basis + dev
lowerBB     = basis - dev
volHigh     = atr > ta.sma(atr, 20) * 1.5
explosive   = volHigh and (rsi > 75 or rsi < 25) and (not volFilter or volUp)
isTrending  = adx > 25 and not explosive
isRanging   = adx < 20 and high <= upperBB and low >= lowerBB and not (adx > 25 or explosive)
isExplosive = explosive and not (adx > 25 or isRanging)

// --- Conditions entree ---
bullTrend          = diplus > diminus and close > ma50
pullbackLong       = low <= ma20 and close > ma20 and rsi > 40 and rsi < 65
entryLT            = isTrending  and bullTrend and pullbackLong
breakoutUp         = close > vah and volHigh and (close - nz(close[1], close)) > atr * 0.8 and (not volFilter or volUp)
entryLE            = isExplosive and breakoutUp

bearTrend          = diminus > diplus and close < ma50
pullbackShort      = high >= ma20 and close < ma20 and rsi > 35 and rsi < 60
entryST            = isTrending  and bearTrend and pullbackShort
breakoutDown       = close < val and volHigh and (close - nz(close[1], close)) < -atr * 0.8 and (not volFilter or volUp)
entrySE            = isExplosive and breakoutDown

strongBull = adx > 30 and diplus  > diminus * 1.5
strongBear = adx > 30 and diminus > diplus  * 1.5
validL     = not strongBear
validS     = not strongBull

// --- SL / TP / Qty ---
calcQty(ep, sp) =>
    dist = math.abs(ep - sp)
    dist := dist == 0 ? 1e-12 : dist
    (stepCapital * riskPerc) / dist

capQty_(qty_raw, ep, sp) =>
    dist = math.abs(ep - sp)
    dist := dist == 0 ? 1e-12 : dist
    math.min(qty_raw, math.min((stepCapital * leverage) / ep, (stepCapital * slCapPct) / dist))

// Long
slBaseL = isRanging ? val * 0.995 : ta.lowest(low, 15) * 0.995
slL     = math.max(slBaseL, close * 0.985)
tpMultL = isTrending ? 4.0 : (isRanging ? 2.5 : 3.3)
tpL     = close + (close - slL) * tpMultL
rawQtyL = math.max(calcQty(close, slL) * leverage, stepCapital * 0.001)
qtyL    = capQty_(rawQtyL, close, slL)

// Short
slBaseS = isRanging ? vah * 1.005 : ta.highest(high, 15) * 1.005
slS     = math.min(slBaseS, close * 1.015)
tpMultS = isTrending ? 4.0 : (isRanging ? 2.5 : 3.3)
tpS     = close - (slS - close) * tpMultS
rawQtyS = math.max(calcQty(close, slS) * leverage, stepCapital * 0.001)
qtyS    = capQty_(rawQtyS, close, slS)

regStr = isTrending ? "trend" : (isRanging ? "range" : "explosive")

// ══════════════════════════════════════════════════════════════════════════════
//  STRATEGY ENTRIES
// ══════════════════════════════════════════════════════════════════════════════
if (entryLT or entryLE) and validL and not inRng
    strategy.cancel_all()
    trailPtsL = close - slL
    strategy.entry("Long", strategy.long, qty=qtyL)
    if trailPtsL > 0
        strategy.exit("Exit Long", from_entry="Long", stop=slL, limit=tpL,
             trail_points=trailPtsL, trail_offset=atr * 1.6)
    else
        strategy.exit("Exit Long", from_entry="Long", stop=slL, limit=tpL)

    alert(
     '{"action":"open"'
     + ',"side":"buy"'
     + ',"symbol":"' + syminfo.ticker + '"'
     + ',"regime":"' + regStr + '"'
     + ',"price":'    + str.tostring(math.round(close, 4))
     + ',"sl":'       + str.tostring(math.round(slL,   4))
     + ',"tp":'       + str.tostring(math.round(tpL,   4))
     + ',"qty":'      + str.tostring(math.round(qtyL,  4))
     + ',"leverage":' + str.tostring(int(leverage))
     + ',"capital":'  + str.tostring(stepCapital)
     + ',"risk_pct":' + str.tostring(riskPerc * 100)
     + '}',
     alert.freq_once_per_bar_close)

if (entryST or entrySE) and validS and not inRng
    strategy.cancel_all()
    trailPtsS = slS - close
    strategy.entry("Short", strategy.short, qty=qtyS)
    if trailPtsS > 0
        strategy.exit("Exit Short", from_entry="Short", stop=slS, limit=tpS,
             trail_points=trailPtsS, trail_offset=atr * 1.6)
    else
        strategy.exit("Exit Short", from_entry="Short", stop=slS, limit=tpS)

    alert(
     '{"action":"open"'
     + ',"side":"sell"'
     + ',"symbol":"' + syminfo.ticker + '"'
     + ',"regime":"' + regStr + '"'
     + ',"price":'    + str.tostring(math.round(close, 4))
     + ',"sl":'       + str.tostring(math.round(slS,   4))
     + ',"tp":'       + str.tostring(math.round(tpS,   4))
     + ',"qty":'      + str.tostring(math.round(qtyS,  4))
     + ',"leverage":' + str.tostring(int(leverage))
     + ',"capital":'  + str.tostring(stepCapital)
     + ',"risk_pct":' + str.tostring(riskPerc * 100)
     + '}',
     alert.freq_once_per_bar_close)

// ══════════════════════════════════════════════════════════════════════════════
//  DETECTION CLOTURE + ALERTE CLOSE
// ══════════════════════════════════════════════════════════════════════════════
var float entryPx  = na
var string entrySd = ""

if (entryLT or entryLE) and validL and not inRng
    entryPx := close
    entrySd := "buy"

if (entryST or entrySE) and validS and not inRng
    entryPx := close
    entrySd := "sell"

prevPos = strategy.position_size[1]
currPos = strategy.position_size

if prevPos != 0.0 and currPos == 0.0 and not na(entryPx)
    exitPx  = close
    pnlPct  = entrySd == "buy" ?
     math.round((exitPx - entryPx) / entryPx * 100, 2) :
     math.round((entryPx - exitPx) / entryPx * 100, 2)
    pnlSign = pnlPct >= 0 ? "GAIN" : "PERTE"
    coin    = syminfo.basecurrency

    alert(
     '{"action":"close"'
     + ',"coin":"'    + coin + '"'
     + ',"symbol":"'  + syminfo.tickerid + '"'
     + ',"side":"'    + entrySd + '"'
     + ',"entry":'    + str.tostring(math.round(entryPx, 4))
     + ',"exit":'     + str.tostring(math.round(exitPx,  4))
     + ',"pnl_pct":'  + str.tostring(pnlPct)
     + ',"equity":'   + str.tostring(math.round(strategy.equity, 2))
     + ',"msg":"'     + pnlSign + ' ' + coin + ' | ' + entrySd
     + ' | Entree:' + str.tostring(math.round(entryPx, 2))
     + ' Sortie:'   + str.tostring(math.round(exitPx,  2))
     + ' PnL:'      + str.tostring(pnlPct) + '%"'
     + '}',
     alert.freq_once_per_bar_close)

// ══════════════════════════════════════════════════════════════════════════════
//  VISUALISATION
// ══════════════════════════════════════════════════════════════════════════════
plot(poc,  "POC",   color=color.fuchsia, linewidth=2)
plot(vah,  "VAH",   color=color.blue,    style=plot.style_circles)
plot(val,  "VAL",   color=color.blue,    style=plot.style_circles)
plot(ma20, "HMA20", color=color.yellow,  linewidth=2)
plot(ma50, "HMA50", color=color.red,     linewidth=2)
plotshape(entryLT or entryLE, title="Long",  location=location.belowbar, color=color.green, style=shape.triangleup)
plotshape(entryST or entrySE, title="Short", location=location.abovebar, color=color.red,   style=shape.triangledown)
bgcolor(inRng ? color.new(color.orange, 90) : na)

// ══════════════════════════════════════════════════════════════════════════════
//  DRAWDOWN + TABLEAU
// ══════════════════════════════════════════════════════════════════════════════
var float peakEq   = startCapital
var float maxDDVal = 0.0
curEq = strategy.equity

if curEq > peakEq
    peakEq := curEq

curDD = (peakEq - curEq) / peakEq
if curDD > maxDDVal
    maxDDVal := curDD

if showStats
    var table stats = table.new(position.top_right, 2, 5,
         border_color=color.new(color.white, 60), border_width=1)
    table.cell(stats, 0, 0, "JP v5.3 30M",       text_color=color.white,  bgcolor=color.new(color.navy, 20), text_size=size.small)
    table.cell(stats, 1, 0, syminfo.ticker,       text_color=color.yellow, bgcolor=color.new(color.navy, 20), text_size=size.small)
    table.cell(stats, 0, 1, "Capital actuel",     text_color=color.gray,   bgcolor=color.new(color.black, 0), text_size=size.tiny)
    table.cell(stats, 1, 1, str.tostring(curEq,  "#.##") + " $",          text_color=color.lime,   bgcolor=color.new(color.black, 0), text_size=size.tiny)
    table.cell(stats, 0, 2, "Perte max/trade",    text_color=color.gray,   bgcolor=color.new(color.black, 0), text_size=size.tiny)
    table.cell(stats, 1, 2, str.tostring(curEq * slCapPct, "#.##") + " $", text_color=color.orange, bgcolor=color.new(color.black, 0), text_size=size.tiny)
    table.cell(stats, 0, 3, "DD Courant",         text_color=color.gray,   bgcolor=color.new(color.black, 0), text_size=size.tiny)
    table.cell(stats, 1, 3, str.tostring(curDD  * 100, "#.##") + "%",     text_color=curDD > maxDD * 0.8 ? color.red : color.white, bgcolor=color.new(color.black, 0), text_size=size.tiny)
    table.cell(stats, 0, 4, "Max DD",             text_color=color.gray,   bgcolor=color.new(color.black, 0), text_size=size.tiny)
    table.cell(stats, 1, 4, str.tostring(maxDDVal * 100, "#.##") + "%",   text_color=color.yellow, bgcolor=color.new(color.black, 0), text_size=size.tiny)

// ══════════════════════════════════════════════════════════════════════════════
//  TABLEAU PARAMETRES (coin gauche)
// ══════════════════════════════════════════════════════════════════════════════
if showParams
    var table params = table.new(position.bottom_left, 2, 8,
         border_color=color.new(color.white, 70), border_width=1)
    table.cell(params, 0, 0, "PARAMETRES",         text_color=color.white,  bgcolor=color.new(color.navy, 10), text_size=size.small)
    table.cell(params, 1, 0, syminfo.ticker,        text_color=color.yellow, bgcolor=color.new(color.navy, 10), text_size=size.small)
    table.cell(params, 0, 1, "Capital",             text_color=color.gray,   bgcolor=color.new(color.black, 0), text_size=size.tiny)
    table.cell(params, 1, 1, str.tostring(startCapital, "#") + " $",         text_color=color.lime,   bgcolor=color.new(color.black, 0), text_size=size.tiny)
    table.cell(params, 0, 2, "Risque/trade",        text_color=color.gray,   bgcolor=color.new(color.black, 0), text_size=size.tiny)
    table.cell(params, 1, 2, str.tostring(riskPerc * 100, "#.#") + "% = " + str.tostring(startCapital * riskPerc, "#.##") + " $", text_color=color.orange, bgcolor=color.new(color.black, 0), text_size=size.tiny)
    table.cell(params, 0, 3, "Leverage",            text_color=color.gray,   bgcolor=color.new(color.black, 0), text_size=size.tiny)
    table.cell(params, 1, 3, str.tostring(int(leverage)) + "x ISOLATED",     text_color=color.aqua,   bgcolor=color.new(color.black, 0), text_size=size.tiny)
    table.cell(params, 0, 4, "SL max cap",          text_color=color.gray,   bgcolor=color.new(color.black, 0), text_size=size.tiny)
    table.cell(params, 1, 4, str.tostring(slCapPct * 100, "#.#") + "% = " + str.tostring(startCapital * slCapPct, "#.##") + " $", text_color=color.red,    bgcolor=color.new(color.black, 0), text_size=size.tiny)
    table.cell(params, 0, 5, "ATR / ADX",          text_color=color.gray,   bgcolor=color.new(color.black, 0), text_size=size.tiny)
    table.cell(params, 1, 5, str.tostring(atrLength) + " / " + str.tostring(adxLength), text_color=color.white, bgcolor=color.new(color.black, 0), text_size=size.tiny)
    table.cell(params, 0, 6, "RSI",                 text_color=color.gray,   bgcolor=color.new(color.black, 0), text_size=size.tiny)
    table.cell(params, 1, 6, str.tostring(rsiLength),                        text_color=color.white,  bgcolor=color.new(color.black, 0), text_size=size.tiny)
    table.cell(params, 0, 7, "Regime actuel",       text_color=color.gray,   bgcolor=color.new(color.black, 0), text_size=size.tiny)
    table.cell(params, 1, 7, regStr,                text_color=isTrending ? color.green : (isRanging ? color.orange : color.fuchsia), bgcolor=color.new(color.black, 0), text_size=size.tiny)

// ——————— ALERTE MAX DD ———————
if maxDDVal >= maxDD
    alert("Attention " + syminfo.ticker + " Max Drawdown >= " + str.tostring(maxDD * 100, "#.##") + "%",
     alert.freq_once_per_bar_close)
