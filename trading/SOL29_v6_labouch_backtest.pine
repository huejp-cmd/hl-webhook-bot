//@version=5
strategy("SOL29 v6 — Labouchère Backtest | SOL 29M",
 overlay=true,
 default_qty_type=strategy.cash,
 commission_type=strategy.commission.percent,
 commission_value=0.1,
 pyramiding=1,
 initial_capital=1000)

// ═══════════════════════════════════════════════════════════════
//  PARAMETRES PRINCIPAUX
// ═══════════════════════════════════════════════════════════════
riskPerc       = input.float(2.0,  "Risque base pct (2%)", step=0.5, minval=0.5, maxval=5.0, group="⚙️ Paramètres Labouchère") / 100
seqInitVal     = input.int(2,      "Valeur initiale séquence (1=standard | 2=agressif)", minval=1, maxval=4, step=1, group="⚙️ Paramètres Labouchère")
leverage       = input.float(2.0,  "Leverage", minval=1.0, step=0.5, group="⚙️ Paramètres Labouchère")
startCapital   = input.float(500.0,"Capital propre $", minval=100, step=100, group="⚙️ Paramètres Labouchère")
marginCapital  = input.float(500.0,"Margin $ (levier série 1)", minval=0, step=100, group="⚙️ Paramètres Labouchère")
slCapPct       = input.float(5.0,  "SL max pct capital", minval=1.0, maxval=20.0, step=0.5, group="⚙️ Paramètres Labouchère") / 100

// ═══════════════════════════════════════════════════════════════
//  PARAMETRES SIGNAL (identiques SOL29 v6 adaptive)
// ═══════════════════════════════════════════════════════════════
useFixedRange  = input.bool(false,  "Plage Fixe (sinon 1xATR)", group="📊 Signal")
fixedRangeSize = input.float(1.2,   "Plage Fixe ($)", step=0.1, minval=0.1, group="📊 Signal")
atrLength      = input.int(10,      "ATR Length", group="📊 Signal")
adxLength      = input.int(14,      "ADX Length", group="📊 Signal")
bbLength       = input.int(20,      "BB Length", group="📊 Signal")
bbMult         = input.float(2.0,   "BB Mult", group="📊 Signal")
rsiLength      = input.int(100,     "RSI Length", group="📊 Signal")
volFilter      = input.bool(true,   "Volume Filter", group="📊 Signal")
volMult        = input.float(1.4,   "Volume Threshold x SMA", step=0.1, group="📊 Signal")
vpK            = input.float(0.75,  "VAH/VAL offset xATR", step=0.05, group="📊 Signal")

// ═══════════════════════════════════════════════════════════════
//  PARAMETRES ADAPTATIF (drawdown protection)
// ═══════════════════════════════════════════════════════════════
adaptMode      = input.bool(true,   "Mode adaptatif DD", group="🛡️ Protection")
adaptLookback  = input.int(50,      "Fenetre analyse barres", minval=20, maxval=200, group="🛡️ Protection")
ddPause        = input.float(10.0,  "DD pause trading pct",    minval=5.0,  maxval=20.0, step=0.5, group="🛡️ Protection") / 100
ddReduce1      = input.float(5.0,   "DD réduction 50pct taille", minval=2.0, maxval=10.0, step=0.5, group="🛡️ Protection") / 100
ddReduce2      = input.float(8.0,   "DD réduction 25pct taille", minval=4.0, maxval=15.0, step=0.5, group="🛡️ Protection") / 100
maxDD          = input.float(13.0,  "Max Drawdown Alert pct",  group="🛡️ Protection") / 100
showStats      = input.bool(true,   "Afficher tableau", group="🛡️ Protection")

// ═══════════════════════════════════════════════════════════════
//  CONSTANTES LABOUCHERE (identiques Python labouch_manager.py)
// ═══════════════════════════════════════════════════════════════
float UNIT_FACTOR  = 0.5   // 1 unité = 0.5× position normale
float LEV_MULT     = 2.0   // levier Labouchère interne
float MAX_MULT     = 6.0   // plafond multiplicateur
float MIN_MULT     = 0.5   // plancher multiplicateur

// ═══════════════════════════════════════════════════════════════
//  ÉTAT LABOUCHERE (persistant entre barres)
// ═══════════════════════════════════════════════════════════════
var int[]  labSeq       = na   // séquence courante
var int    lastClosed   = 0    // nb trades fermés au dernier check
var int    labWins      = 0
var int    labLosses    = 0
var float  labPeakMult  = 0.0

// Initialisation séquence
if na(labSeq)
    labSeq := array.new<int>(4, seqInitVal)

// ─── Calcul bet_units + multiplicateur (barre courante) ───
labSz   = array.size(labSeq)
labBet  = labSz <= 0 ? seqInitVal * 2 :
          labSz == 1 ? array.get(labSeq, 0) * 2 :
                       array.get(labSeq, 0) + array.get(labSeq, labSz - 1)
labMult = math.max(MIN_MULT, math.min(MAX_MULT, labBet * UNIT_FACTOR * LEV_MULT))

if labMult > labPeakMult
    labPeakMult := labMult

// ─── Mise à jour séquence sur trade fermé ───
if strategy.closedtrades > lastClosed
    tradeProfit = strategy.closedtrades.profit(strategy.closedtrades - 1)
    currentBet  = labBet   // valeur au moment de la clôture

    if tradeProfit > 0
        // WIN → ajoute bet_units à la fin
        array.push(labSeq, currentBet)
        labWins += 1
    else
        // LOSS → barre premier + dernier
        sz = array.size(labSeq)
        if sz >= 2
            array.remove(labSeq, sz - 1)
            array.remove(labSeq, 0)
        else if sz == 1
            array.clear(labSeq)
        // Reset si séquence vide
        if array.size(labSeq) == 0
            for _i = 0 to 3
                array.push(labSeq, seqInitVal)
        labLosses += 1

    lastClosed := strategy.closedtrades

// ═══════════════════════════════════════════════════════════════
//  CAPITAL ACTIF = Capital propre + Margin (comme bot Python)
//  Série 1 : capital propre + margin → activeCapital = 1000
//  Séries suivantes : sans margin (après ceiling)
// ═══════════════════════════════════════════════════════════════
activeCapital = startCapital + marginCapital   // 500 + 500 = 1000

// ── Compound long terme (comme bot Python) ──────────────────────
// Le bot Python scale les positions selon l'equity réelle du compte
// real_capital = equity × (base / total_base)
// Plancher à 50% de la base pour éviter les positions trop petites
// en cas de drawdown temporaire
equityNow   = strategy.equity
compoundCap = math.max(equityNow, activeCapital * 0.5)   // plancher 50%
stepCapital = compoundCap

// ═══════════════════════════════════════════════════════════════
//  RANGE BARS (identique v6 original)
// ═══════════════════════════════════════════════════════════════
var float rangeOpen  = na
var float rangeHigh  = na
var float rangeLow   = na
var float rangeClose = na
var int   barCount   = 0

if na(rangeOpen)
    rangeOpen  := open
    rangeHigh  := high
    rangeLow   := low
    rangeClose := close

rangeHigh  := math.max(rangeHigh, high)
rangeLow   := math.min(rangeLow,  low)
rangeClose := close

rangeSize = useFixedRange ? fixedRangeSize : ta.atr(atrLength)
isNewBar  = math.abs(close - rangeOpen) >= rangeSize

if isNewBar
    barCount  += 1
    rangeOpen := close
    rangeHigh := high
    rangeLow  := low

o = rangeOpen
h = rangeHigh
l = rangeLow
c = rangeClose

// ═══════════════════════════════════════════════════════════════
//  INDICATEURS
// ═══════════════════════════════════════════════════════════════
hullMa(src, length) =>
    n2      = math.floor(length / 2)
    sqrtLen = math.floor(math.sqrt(length))
    wma1    = ta.wma(src, n2)
    wma2    = ta.wma(src, length)
    delta   = 2 * wma1 - wma2
    ta.wma(delta, sqrtLen)

calcAtr(len) =>
    cPrev = nz(c[1], c)
    tr    = math.max(math.max(h - l, math.abs(h - cPrev)), math.abs(l - cPrev))
    ta.rma(tr, len)

atr      = calcAtr(atrLength)
atrSma   = ta.sma(atr, adaptLookback)
rsi      = ta.rsi(c, rsiLength)
volSma   = ta.sma(volume, 20)
volumeUp = volume > volSma * volMult
ma20     = hullMa(c, 20)
ma50     = hullMa(c, 50)

cumVol = ta.cum(volume)
cumPV  = ta.cum(((h + l + c) / 3) * volume)
vwap   = cumPV / nz(cumVol, 1)
vah    = ta.highest(vwap + vpK * atr, 24)
val    = ta.lowest( vwap - vpK * atr, 24)
poc    = vwap

calcDmi(length) =>
    cPrev   = nz(c[1], c)
    up      = math.max(ta.change(h), 0)
    dn      = math.max(-ta.change(l), 0)
    pDM     = (up > dn and up > 0)    ? up : 0
    mDM     = (dn > up and dn > 0)    ? dn : 0
    trur    = math.max(math.max(h - l, math.abs(h - cPrev)), math.abs(l - cPrev))
    sPlus   = ta.rma(pDM,  length)
    sMinus  = ta.rma(mDM,  length)
    sTrur   = ta.rma(trur, length)
    dip     = sTrur != 0 ? 100 * sPlus  / sTrur : 0.0
    dim     = sTrur != 0 ? 100 * sMinus / sTrur : 0.0
    dx      = (dip + dim) != 0 ? 100 * math.abs(dip - dim) / (dip + dim) : 0.0
    [dip, dim, ta.rma(dx, length)]

[diplus, diminus, adx] = calcDmi(adxLength)

var float[] volWindow = array.new_float()
currentVol = ta.stdev(math.log(high / low), 100)
array.push(volWindow, currentVol)
if array.size(volWindow) > 100
    array.shift(volWindow)
sortedVol = array.copy(volWindow)
array.sort(sortedVol, order.ascending)
idx25      = math.round((array.size(sortedVol) - 1) * 0.25)
vol25      = array.get(sortedVol, math.min(idx25, array.size(sortedVol) - 1))

btcH1h     = request.security("BINANCE:BTCUSDT", "60", high)
btcL1h     = request.security("BINANCE:BTCUSDT", "60", low)
btcC1h     = request.security("BINANCE:BTCUSDT", "60", close[1])
btcRange1h = (btcH1h - btcL1h) / btcC1h

inRange = (adx < 20) and (currentVol < vol25) and (btcRange1h < 0.01)
bgcolor(inRange ? color.new(color.orange, 90) : na)

// ═══════════════════════════════════════════════════════════════
//  REGIMES
// ═══════════════════════════════════════════════════════════════
trending       = adx > 25
basis          = ta.sma(c, bbLength)
dev            = bbMult * ta.stdev(c, bbLength)
upperBB        = basis + dev
lowerBB        = basis - dev
ranging        = adx < 20 and h <= upperBB and l >= lowerBB
volatilityHigh = atr > atrSma * 1.5
volatilityLow  = atr < atrSma * 0.7
explosive      = volatilityHigh and (rsi > 75 or rsi < 25) and (not volFilter or volumeUp)
isExplosive    = explosive and not (trending or ranging)
isTrending     = trending  and not explosive
isRanging      = ranging   and not (trending or explosive)

// ═══════════════════════════════════════════════════════════════
//  DRAWDOWN + PROTECTION ADAPTATIVE
// ═══════════════════════════════════════════════════════════════
var float peakEquity     = startCapital
var float maxDrawdownVal = 0.0
currentEquity = strategy.equity
if currentEquity > peakEquity
    peakEquity := currentEquity
currentDD = peakEquity > 0 ? (peakEquity - currentEquity) / peakEquity : 0.0
if currentDD > maxDrawdownVal
    maxDrawdownVal := currentDD

adaptAtrMult  = not adaptMode ? 1.2 : volatilityHigh ? 1.8 : volatilityLow ? 0.9 : 1.2
tpBase        = isTrending ? 4.0 : isRanging ? 2.5 : 3.3
adaptTpMult   = not adaptMode ? tpBase : adx > 35 ? tpBase * 1.5 : adx > 25 ? tpBase * 1.2 : tpBase * 0.9

rsiLongMin    = not adaptMode ? 40.0 : volatilityHigh ? 35.0 : volatilityLow ? 42.0 : 40.0
rsiLongMax    = not adaptMode ? 65.0 : volatilityHigh ? 68.0 : volatilityLow ? 60.0 : 65.0
rsiShortMin   = not adaptMode ? 35.0 : volatilityHigh ? 32.0 : volatilityLow ? 40.0 : 35.0
rsiShortMax   = not adaptMode ? 60.0 : volatilityHigh ? 65.0 : volatilityLow ? 58.0 : 60.0

sizeFactor    = not adaptMode ? 1.0 : currentDD >= ddPause ? 0.0 : currentDD >= ddReduce2 ? 0.25 : currentDD >= ddReduce1 ? 0.5 : 1.0
tradingPaused = adaptMode and currentDD >= ddPause

bgcolor(tradingPaused ? color.new(color.red, 80) : currentDD >= ddReduce2 ? color.new(color.orange, 88) : currentDD >= ddReduce1 ? color.new(color.yellow, 92) : na, title="Protection DD")

// ═══════════════════════════════════════════════════════════════
//  CONDITIONS D'ENTRÉE
// ═══════════════════════════════════════════════════════════════
bullTrend           = diplus > diminus and c > ma50
pullbackLong        = l <= ma20 and c > ma20 and rsi > rsiLongMin and rsi < rsiLongMax
entryLongTrend      = isTrending and bullTrend and pullbackLong
breakoutUp          = c > vah and volatilityHigh and (c - nz(c[1], c)) > atr * 0.8 and (not volFilter or volumeUp)
entryLongExplosive  = isExplosive and breakoutUp

bearTrend           = diminus > diplus and c < ma50
pullbackShort       = h >= ma20 and c < ma20 and rsi > rsiShortMin and rsi < rsiShortMax
entryShortTrend     = isTrending and bearTrend and pullbackShort
breakoutDown        = c < val and volatilityHigh and (c - nz(c[1], c)) < -atr * 0.8 and (not volFilter or volumeUp)
entryShortExplosive = isExplosive and breakoutDown

strongBull = adx > 30 and diplus  > diminus * 1.5
strongBear = adx > 30 and diminus > diplus  * 1.5
validLong  = not strongBear and not tradingPaused
validShort = not strongBull and not tradingPaused

// ═══════════════════════════════════════════════════════════════
//  CALCUL QUANTITE AVEC MULTIPLICATEUR LABOUCHERE
// ═══════════════════════════════════════════════════════════════
calcQty(entryPrice, slPrice) =>
    dist = math.abs(entryPrice - slPrice)
    dist := dist == 0 ? 1e-12 : dist
    (stepCapital * riskPerc) / dist

capQty(qty_raw, entryPrice, slPrice) =>
    dist      = math.abs(entryPrice - slPrice)
    dist      := dist == 0 ? 1e-12 : dist
    qtyCapExp = (stepCapital * leverage) / entryPrice
    qtyCapSL  = (stepCapital * slCapPct) / dist
    math.min(qty_raw, math.min(qtyCapExp, qtyCapSL)) * sizeFactor

// ═══════════════════════════════════════════════════════════════
//  ENTRÉES LONG
// ═══════════════════════════════════════════════════════════════
if (entryLongTrend or entryLongExplosive) and validLong and not inRange
    strategy.cancel_all()
    slBase      = isRanging ? val * 0.995 : ta.lowest(l, 15) * 0.995
    slPrice     = math.max(slBase, c * 0.985)
    tpPrice     = c + (c - slPrice) * adaptTpMult
    baseQty     = calcQty(c, slPrice)
    // ► Labouchère : applique le multiplicateur sur rawQty
    rawQty      = nz(baseQty * leverage * labMult, stepCapital * 0.001)
    rawQty      := rawQty <= 0 ? stepCapital * 0.001 : rawQty
    qty         = capQty(rawQty, c, slPrice)
    trailPoints = c - slPrice
    strategy.entry("Long", strategy.long, qty=qty)
    if trailPoints > 0
        strategy.exit("Exit Long", from_entry="Long", stop=slPrice, limit=tpPrice, trail_points=trailPoints, trail_offset=atr * adaptAtrMult)
    else
        strategy.exit("Exit Long", from_entry="Long", stop=slPrice, limit=tpPrice)

// ═══════════════════════════════════════════════════════════════
//  ENTRÉES SHORT
// ═══════════════════════════════════════════════════════════════
if (entryShortTrend or entryShortExplosive) and validShort and not inRange
    strategy.cancel_all()
    slBase      = isRanging ? vah * 1.005 : ta.highest(h, 15) * 1.005
    slPrice     = math.min(slBase, c * 1.015)
    tpPrice     = c - (slPrice - c) * adaptTpMult
    baseQty     = calcQty(c, slPrice)
    // ► Labouchère : applique le multiplicateur sur rawQty
    rawQty      = nz(baseQty * leverage * labMult, stepCapital * 0.001)
    rawQty      := rawQty <= 0 ? stepCapital * 0.001 : rawQty
    qty         = capQty(rawQty, c, slPrice)
    trailPoints = slPrice - c
    strategy.entry("Short", strategy.short, qty=qty)
    if trailPoints > 0
        strategy.exit("Exit Short", from_entry="Short", stop=slPrice, limit=tpPrice, trail_points=trailPoints, trail_offset=atr * adaptAtrMult)
    else
        strategy.exit("Exit Short", from_entry="Short", stop=slPrice, limit=tpPrice)

// ═══════════════════════════════════════════════════════════════
//  VISUALISATION
// ═══════════════════════════════════════════════════════════════
bgcolor(isNewBar ? color.new(color.blue, 95) : na)
plot(poc,  "POC",   color=color.fuchsia, linewidth=2)
plot(vah,  "VAH",   color=color.blue,    style=plot.style_circles)
plot(val,  "VAL",   color=color.blue,    style=plot.style_circles)
plot(ma20, "HMA20", color=color.yellow,  linewidth=2)
plot(ma50, "HMA50", color=color.red,     linewidth=2)
plotshape(isNewBar,                               title="New Range", location=location.belowbar, color=color.blue,  style=shape.circle,        size=size.tiny)
plotshape(entryLongTrend or entryLongExplosive,   title="Long",      location=location.belowbar, color=color.green, style=shape.triangleup)
plotshape(entryShortTrend or entryShortExplosive, title="Short",     location=location.abovebar, color=color.red,   style=shape.triangledown)

// ═══════════════════════════════════════════════════════════════
//  TABLEAU DE BORD LABOUCHERE
// ═══════════════════════════════════════════════════════════════
if showStats
    var table t = table.new(position.top_right, 2, 18,
     border_color=color.new(color.white, 60), border_width=1)

    // ── En-tête ──
    seqLabel = seqInitVal == 1 ? "[1,1,1,1]" : seqInitVal == 2 ? "[2,2,2,2]" : "[" + str.tostring(seqInitVal) + "×4]"
    riskLabel = str.tostring(riskPerc * 100, "#.#") + "%"
    table.cell(t, 0, 0, "SOL29 Labouchère",
     text_color=color.white,  bgcolor=color.new(color.navy, 10), text_size=size.small)
    table.cell(t, 1, 0, seqLabel + " | risk=" + riskLabel,
     text_color=color.yellow, bgcolor=color.new(color.navy, 10), text_size=size.small)

    // ── Capital ──
    table.cell(t, 0, 1, "Capital propre",   text_color=color.gray,  bgcolor=color.new(color.black, 0), text_size=size.tiny)
    table.cell(t, 1, 1, str.tostring(startCapital, "#") + " $",
     text_color=color.white, bgcolor=color.new(color.black, 0), text_size=size.tiny)
    table.cell(t, 0, 2, "Margin (série 1)", text_color=color.gray,  bgcolor=color.new(color.black, 0), text_size=size.tiny)
    table.cell(t, 1, 2, str.tostring(marginCapital, "#") + " $",
     text_color=color.aqua,  bgcolor=color.new(color.black, 0), text_size=size.tiny)
    table.cell(t, 0, 3, "Capital actif",    text_color=color.gray,  bgcolor=color.new(color.black, 0), text_size=size.tiny)
    table.cell(t, 1, 3, str.tostring(activeCapital, "#") + " $ (base)",
     text_color=color.lime,  bgcolor=color.new(color.black, 0), text_size=size.tiny)
    table.cell(t, 0, 4, "Capital compound", text_color=color.gray,  bgcolor=color.new(color.black, 0), text_size=size.tiny)
    table.cell(t, 1, 4, str.tostring(compoundCap, "#.##") + " $ 📈",
     text_color=compoundCap > activeCapital ? color.lime : compoundCap < activeCapital ? color.red : color.white,
     bgcolor=color.new(color.black, 0), text_size=size.tiny)

    // ── Labouchère ──
    table.cell(t, 0, 5,  "Séquence init",    text_color=color.gray,  bgcolor=color.new(color.black, 0), text_size=size.tiny)
    table.cell(t, 1, 5,  seqLabel,           text_color=color.white, bgcolor=color.new(color.black, 0), text_size=size.tiny)
    table.cell(t, 0, 6,  "Bet units",        text_color=color.gray,  bgcolor=color.new(color.black, 0), text_size=size.tiny)
    table.cell(t, 1, 6,  str.tostring(labBet) + " u",
     text_color=labBet > 6 ? color.red : labBet > 4 ? color.orange : color.lime, bgcolor=color.new(color.black, 0), text_size=size.tiny)
    table.cell(t, 0, 7,  "Multiplicateur",   text_color=color.gray,  bgcolor=color.new(color.black, 0), text_size=size.tiny)
    table.cell(t, 1, 7,  str.tostring(labMult, "#.##") + "×",
     text_color=labMult >= 5.0 ? color.red : labMult >= 3.0 ? color.orange : color.lime, bgcolor=color.new(color.black, 0), text_size=size.tiny)
    table.cell(t, 0, 8,  "Mult max atteint", text_color=color.gray,  bgcolor=color.new(color.black, 0), text_size=size.tiny)
    table.cell(t, 1, 8,  str.tostring(labPeakMult, "#.##") + "×",
     text_color=color.aqua, bgcolor=color.new(color.black, 0), text_size=size.tiny)
    table.cell(t, 0, 9,  "Séq. longueur",    text_color=color.gray,  bgcolor=color.new(color.black, 0), text_size=size.tiny)
    table.cell(t, 1, 9,  str.tostring(array.size(labSeq)) + " éléments",
     text_color=color.white, bgcolor=color.new(color.black, 0), text_size=size.tiny)
    table.cell(t, 0, 10, "Wins / Losses",    text_color=color.gray,  bgcolor=color.new(color.black, 0), text_size=size.tiny)
    table.cell(t, 1, 10, str.tostring(labWins) + "W / " + str.tostring(labLosses) + "L",
     text_color=labWins > labLosses ? color.lime : color.red, bgcolor=color.new(color.black, 0), text_size=size.tiny)

    // ── Performance ──
    totalTrades   = strategy.closedtrades
    winTrades     = strategy.wintrades
    lossTrades    = strategy.losstrades
    winRate       = totalTrades > 0 ? winTrades / totalTrades * 100 : 0.0
    netProfit     = strategy.netprofit
    netProfitPct  = activeCapital > 0 ? netProfit / activeCapital * 100 : 0.0

    table.cell(t, 0, 11, "── Perf ──",       text_color=color.gray,  bgcolor=color.new(color.navy, 50), text_size=size.tiny)
    table.cell(t, 1, 11, "",                  text_color=color.gray,  bgcolor=color.new(color.navy, 50), text_size=size.tiny)
    table.cell(t, 0, 12, "Net Profit",        text_color=color.gray,  bgcolor=color.new(color.black, 0), text_size=size.tiny)
    table.cell(t, 1, 12, str.tostring(netProfit, "#.##") + " $ (" + str.tostring(netProfitPct, "#.#") + "%)",
     text_color=netProfit >= 0 ? color.lime : color.red, bgcolor=color.new(color.black, 0), text_size=size.tiny)
    table.cell(t, 0, 13, "Win Rate",          text_color=color.gray,  bgcolor=color.new(color.black, 0), text_size=size.tiny)
    table.cell(t, 1, 13, str.tostring(winRate, "#.#") + "% (" + str.tostring(totalTrades) + " trades)",
     text_color=winRate >= 50 ? color.lime : color.orange, bgcolor=color.new(color.black, 0), text_size=size.tiny)
    table.cell(t, 0, 14, "Max DD",            text_color=color.gray,  bgcolor=color.new(color.black, 0), text_size=size.tiny)
    table.cell(t, 1, 14, str.tostring(maxDrawdownVal * 100, "#.##") + "%",
     text_color=maxDrawdownVal > 0.15 ? color.red : maxDrawdownVal > 0.08 ? color.orange : color.lime, bgcolor=color.new(color.black, 0), text_size=size.tiny)

    // ── Régime / DD ──
    table.cell(t, 0, 15, "── Marché ──",     text_color=color.gray,  bgcolor=color.new(color.navy, 50), text_size=size.tiny)
    table.cell(t, 1, 15, "",                  text_color=color.gray,  bgcolor=color.new(color.navy, 50), text_size=size.tiny)
    table.cell(t, 0, 16, "Régime",            text_color=color.gray,  bgcolor=color.new(color.black, 0), text_size=size.tiny)
    table.cell(t, 1, 16, isTrending ? "TREND" : isRanging ? "RANGE" : isExplosive ? "EXPLO" : "NEUTRE",
     text_color=isTrending ? color.lime : isRanging ? color.orange : isExplosive ? color.red : color.gray,
     bgcolor=color.new(color.black, 0), text_size=size.tiny)
    table.cell(t, 0, 17, "Trading",           text_color=color.gray,  bgcolor=color.new(color.black, 0), text_size=size.tiny)
    table.cell(t, 1, 17, tradingPaused ? "⛔ PAUSE DD" : "✅ ACTIF",
     text_color=tradingPaused ? color.red : color.lime, bgcolor=color.new(color.black, 0), text_size=size.tiny)

// ═══════════════════════════════════════════════════════════════
//  ALERTES
// ═══════════════════════════════════════════════════════════════
if maxDrawdownVal >= maxDD
    alert("⚠️ Max DD >= " + str.tostring(maxDD * 100, "#.##") + "%", alert.freq_once_per_bar)
if tradingPaused and not tradingPaused[1]
    alert("🛑 TRADING PAUSE DD > " + str.tostring(ddPause * 100, "#.##") + "%", alert.freq_once_per_bar)
if labMult >= MAX_MULT and labMult[1] < MAX_MULT
    alert("🔥 Labouchère PLAFOND atteint : mult=" + str.tostring(labMult, "#.##") + "×", alert.freq_once_per_bar)
