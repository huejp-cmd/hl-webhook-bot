//@version=5
//
//  ╔═══════════════════════════════════════════════════════╗
//  ║  SOL29 v6 — LIVE SIGNAL | SOL 29M                   ║
//  ║  Génère les alertes webhook pour hl_webhook_server   ║
//  ║  Chart : BYBIT:SOLUSDT.P  —  Timeframe : 29M         ║
//  ║  Signaux identiques au backtest validé (1 an)         ║
//  ╚═══════════════════════════════════════════════════════╝
//
indicator("SOL29 v6 — Live | SOL 29M", overlay=true, max_bars_back=500)

// ── Symbole ──────────────────────────────────────────────────
hlCoin   = "SOL"
whSymbol = "SOLUSDT.P"

// ════════════════════════════════════════════════════════════
//  PARAMÈTRES
// ════════════════════════════════════════════════════════════
g_mode = "⚙️ Mode"
testMode = input.bool(false, "[TEST] Désactiver alertes webhook", group=g_mode)

g_capital = "💰 Capital"
startCapital = input.float(500.0, "Capital propre $", step=100, minval=100, group=g_capital)

g_signal = "📊 Signal"
useFixedRange  = input.bool(false,  "Plage Fixe (sinon 1xATR)", group=g_signal)
fixedRangeSize = input.float(1.2,   "Plage Fixe ($)", step=0.1, minval=0.1, group=g_signal)
atrLength      = input.int(10,      "ATR Length", group=g_signal)
adxLength      = input.int(14,      "ADX Length", group=g_signal)
bbLength       = input.int(20,      "BB Length", group=g_signal)
bbMult         = input.float(2.0,   "BB Mult", group=g_signal)
rsiLength      = input.int(100,     "RSI Length", group=g_signal)
volFilter      = input.bool(true,   "Volume Filter", group=g_signal)
volMult        = input.float(1.4,   "Volume Threshold x SMA", step=0.1, group=g_signal)
vpK            = input.float(0.75,  "VAH/VAL offset xATR", step=0.05, group=g_signal)

g_protect = "🛡️ Protection DD"
adaptMode      = input.bool(true,   "Mode adaptatif DD", group=g_protect)
adaptLookback  = input.int(50,      "Fenetre analyse barres", group=g_protect)
ddPause        = input.float(10.0,  "DD pause trading pct", step=0.5, group=g_protect) / 100
ddReduce1      = input.float(5.0,   "DD réduction 50%", step=0.5, group=g_protect) / 100
ddReduce2      = input.float(8.0,   "DD réduction 25%", step=0.5, group=g_protect) / 100

// ════════════════════════════════════════════════════════════
//  RANGE BARS
// ════════════════════════════════════════════════════════════
var float rangeOpen  = na
var float rangeHigh  = na
var float rangeLow   = na
var float rangeClose = na
var int   barCount   = 0

if na(rangeOpen)
    rangeOpen  := open
    rangeHigh  := high
    rangeLow   := low
    rangeClose := close

rangeHigh  := math.max(rangeHigh, high)
rangeLow   := math.min(rangeLow,  low)
rangeClose := close

rangeSize = useFixedRange ? fixedRangeSize : ta.atr(atrLength)
isNewBar  = math.abs(close - rangeOpen) >= rangeSize

if isNewBar
    barCount  += 1
    rangeOpen := close
    rangeHigh := high
    rangeLow  := low

o = rangeOpen
h = rangeHigh
l = rangeLow
c = rangeClose

// ════════════════════════════════════════════════════════════
//  INDICATEURS
// ════════════════════════════════════════════════════════════
hullMa(src, length) =>
    n2      = math.floor(length / 2)
    sqrtLen = math.floor(math.sqrt(length))
    wma1    = ta.wma(src, n2)
    wma2    = ta.wma(src, length)
    delta   = 2 * wma1 - wma2
    ta.wma(delta, sqrtLen)

calcAtr(len) =>
    cPrev = nz(c[1], c)
    tr    = math.max(math.max(h - l, math.abs(h - cPrev)), math.abs(l - cPrev))
    ta.rma(tr, len)

atr      = calcAtr(atrLength)
atrSma   = ta.sma(atr, adaptLookback)
rsi      = ta.rsi(c, rsiLength)
volSma   = ta.sma(volume, 20)
volumeUp = volume > volSma * volMult
hma20    = hullMa(c, 20)
hma50    = hullMa(c, 50)

cumVol = ta.cum(volume)
cumPV  = ta.cum(((h + l + c) / 3) * volume)
vwap   = cumPV / nz(cumVol, 1)
vah    = ta.highest(vwap + vpK * atr, 24)
val    = ta.lowest( vwap - vpK * atr, 24)

calcDmi(length) =>
    cPrev   = nz(c[1], c)
    up      = math.max(ta.change(h), 0)
    dn      = math.max(-ta.change(l), 0)
    pDM     = (up > dn and up > 0)    ? up : 0
    mDM     = (dn > up and dn > 0)    ? dn : 0
    trur    = math.max(math.max(h - l, math.abs(h - cPrev)), math.abs(l - cPrev))
    sPlus   = ta.rma(pDM,  length)
    sMinus  = ta.rma(mDM,  length)
    sTrur   = ta.rma(trur, length)
    dip     = sTrur != 0 ? 100 * sPlus  / sTrur : 0.0
    dim     = sTrur != 0 ? 100 * sMinus / sTrur : 0.0
    dx      = (dip + dim) != 0 ? 100 * math.abs(dip - dim) / (dip + dim) : 0.0
    [dip, dim, ta.rma(dx, length)]

[diplus, diminus, adx] = calcDmi(adxLength)

var float[] volWindow = array.new_float()
currentVol = ta.stdev(math.log(high / low), 100)
array.push(volWindow, currentVol)
if array.size(volWindow) > 100
    array.shift(volWindow)
sortedVol = array.copy(volWindow)
array.sort(sortedVol, order.ascending)
idx25  = math.round((array.size(sortedVol) - 1) * 0.25)
vol25  = array.get(sortedVol, math.min(idx25, array.size(sortedVol) - 1))

btcH1h     = request.security("BINANCE:BTCUSDT", "60", high)
btcL1h     = request.security("BINANCE:BTCUSDT", "60", low)
btcC1h     = request.security("BINANCE:BTCUSDT", "60", close[1])
btcRange1h = (btcH1h - btcL1h) / nz(btcC1h, 1)

inRange = (adx < 20) and (currentVol < vol25) and (btcRange1h < 0.01)

// ════════════════════════════════════════════════════════════
//  RÉGIMES
// ════════════════════════════════════════════════════════════
trending       = adx > 25
basis          = ta.sma(c, bbLength)
dev            = bbMult * ta.stdev(c, bbLength)
upperBB        = basis + dev
lowerBB        = basis - dev
ranging        = adx < 20 and h <= upperBB and l >= lowerBB
volatilityHigh = atr > atrSma * 1.5
volatilityLow  = atr < atrSma * 0.7
explosive      = volatilityHigh and (rsi > 75 or rsi < 25) and (not volFilter or volumeUp)
isExplosive    = explosive and not (trending or ranging)
isTrending     = trending  and not explosive
isRanging      = ranging   and not (trending or explosive)

regStr = isTrending ? "trend" : isExplosive ? "explosive" : "range"

// ════════════════════════════════════════════════════════════
//  PROTECTION DRAWDOWN (indicatif — bot a son propre suivi)
// ════════════════════════════════════════════════════════════
var float peakCap     = startCapital
currentEquityEst      = startCapital   // pas d'equity réelle en indicator
currentDD             = 0.0            // DD géré côté bot
tradingPaused         = false

adaptAtrMult  = not adaptMode ? 1.2 : volatilityHigh ? 1.8 : volatilityLow ? 0.9 : 1.2
tpBase        = isTrending ? 4.0 : isRanging ? 2.5 : 3.3
adaptTpMult   = not adaptMode ? tpBase : adx > 35 ? tpBase * 1.5 : adx > 25 ? tpBase * 1.2 : tpBase * 0.9

rsiLongMin    = not adaptMode ? 40.0 : volatilityHigh ? 35.0 : volatilityLow ? 42.0 : 40.0
rsiLongMax    = not adaptMode ? 65.0 : volatilityHigh ? 68.0 : volatilityLow ? 60.0 : 65.0
rsiShortMin   = not adaptMode ? 35.0 : volatilityHigh ? 32.0 : volatilityLow ? 40.0 : 35.0
rsiShortMax   = not adaptMode ? 60.0 : volatilityHigh ? 65.0 : volatilityLow ? 58.0 : 60.0

// ════════════════════════════════════════════════════════════
//  CONDITIONS D'ENTRÉE (identiques au backtest)
// ════════════════════════════════════════════════════════════
rsiOK  = rsi > rsiLongMin and rsi < rsiLongMax
adxOK  = adx > 15

bullTrend           = diplus > diminus and c > hma50
pullbackLong        = l <= hma20 and c > hma20 and rsi > rsiLongMin and rsi < rsiLongMax
entryLongTrend      = isTrending and bullTrend and pullbackLong
breakoutUp          = c > vah and volatilityHigh and (c - nz(c[1], c)) > atr * 0.8 and (not volFilter or volumeUp)
entryLongExplosive  = isExplosive and breakoutUp

bearTrend           = diminus > diplus and c < hma50
pullbackShort       = h >= hma20 and c < hma20 and rsi > rsiShortMin and rsi < rsiShortMax
entryShortTrend     = isTrending and bearTrend and pullbackShort
breakoutDown        = c < val and volatilityHigh and (c - nz(c[1], c)) < -atr * 0.8 and (not volFilter or volumeUp)
entryShortExplosive = isExplosive and breakoutDown

strongBull = adx > 30 and diplus  > diminus * 1.5
strongBear = adx > 30 and diminus > diplus  * 1.5
validLong  = not strongBear and not tradingPaused
validShort = not strongBull and not tradingPaused

goLong  = (entryLongTrend  or entryLongExplosive)  and validLong  and not inRange
goShort = (entryShortTrend or entryShortExplosive) and validShort and not inRange

// ════════════════════════════════════════════════════════════
//  CALCUL SL / TP
// ════════════════════════════════════════════════════════════
slLong  = math.max(isRanging ? val * 0.995 : ta.lowest(l, 15) * 0.995, c * 0.985)
tpLong  = c + (c - slLong) * adaptTpMult

slShort = math.min(isRanging ? vah * 1.005 : ta.highest(h, 15) * 1.005, c * 1.015)
tpShort = c - (slShort - c) * adaptTpMult

// ════════════════════════════════════════════════════════════
//  ALERTES WEBHOOK
// ════════════════════════════════════════════════════════════
if goLong and not testMode
    alert(
     '{"action":"open","side":"buy","symbol":"' + whSymbol + '"' +
     ',"coin":"' + hlCoin + '"' +
     ',"price":' + str.tostring(math.round(c, 4)) +
     ',"sl":'    + str.tostring(math.round(slLong,  4)) +
     ',"tp":'    + str.tostring(math.round(tpLong,  4)) +
     ',"capital":' + str.tostring(startCapital) +
     ',"regime":"' + regStr + '"' +
     ',"tf":"'   + timeframe.period + '"' +
     ',"adx":'   + str.tostring(math.round(adx, 1)) +
     ',"rsi":'   + str.tostring(math.round(rsi, 1)) +
     '}',
     alert.freq_once_per_bar_close)

if goShort and not testMode
    alert(
     '{"action":"open","side":"sell","symbol":"' + whSymbol + '"' +
     ',"coin":"' + hlCoin + '"' +
     ',"price":' + str.tostring(math.round(c, 4)) +
     ',"sl":'    + str.tostring(math.round(slShort, 4)) +
     ',"tp":'    + str.tostring(math.round(tpShort, 4)) +
     ',"capital":' + str.tostring(startCapital) +
     ',"regime":"' + regStr + '"' +
     ',"tf":"'   + timeframe.period + '"' +
     ',"adx":'   + str.tostring(math.round(adx, 1)) +
     ',"rsi":'   + str.tostring(math.round(rsi, 1)) +
     '}',
     alert.freq_once_per_bar_close)

// ════════════════════════════════════════════════════════════
//  VISUALISATION
// ════════════════════════════════════════════════════════════
plot(hma20, "HMA 20", color=color.new(color.teal,   0), linewidth=1)
plot(hma50, "HMA 50", color=color.new(color.purple,  0), linewidth=1)
plot(vah,   "VAH",    color=color.new(color.green,  40), linewidth=1, style=plot.style_line)
plot(val,   "VAL",    color=color.new(color.red,    40), linewidth=1, style=plot.style_line)

plotshape(goLong  and barstate.isconfirmed, "LONG",  shape.triangleup,   location.belowbar, color.new(color.green, 0), size=size.small)
plotshape(goShort and barstate.isconfirmed, "SHORT", shape.triangledown, location.abovebar, color.new(color.red,   0), size=size.small)

bgcolor(inRange       ? color.new(color.orange, 90) : na, title="Range")
bgcolor(tradingPaused ? color.new(color.red,    80) : na, title="Pause DD")

// Tableau
if showStats := true
    var table t = table.new(position.top_right, 2, 5, border_width=1)
    table.cell(t, 0, 0, "SOL29 v6 LIVE",  text_color=color.white, bgcolor=color.navy)
    table.cell(t, 1, 0, "29M",            text_color=color.white, bgcolor=color.navy)
    table.cell(t, 0, 1, "ADX",  text_color=color.gray)
    table.cell(t, 1, 1, str.tostring(math.round(adx, 1)), text_color=adx > 25 ? color.green : color.gray)
    table.cell(t, 0, 2, "RSI",  text_color=color.gray)
    table.cell(t, 1, 2, str.tostring(math.round(rsi, 1)), text_color=rsi > 60 ? color.red : rsi < 40 ? color.green : color.gray)
    table.cell(t, 0, 3, "Régime", text_color=color.gray)
    table.cell(t, 1, 3, regStr, text_color=isTrending ? color.green : isExplosive ? color.orange : color.gray)
    table.cell(t, 0, 4, "Mode", text_color=color.gray)
    table.cell(t, 1, 4, testMode ? "TEST" : "LIVE", text_color=testMode ? color.orange : color.lime, bgcolor=testMode ? color.new(color.orange, 80) : color.new(color.green, 80))
