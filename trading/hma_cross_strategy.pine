//@version=5
strategy("HMA Cross + Labouchère Inversée 🐢", 
         overlay              = true, 
         pyramiding           = 1,
         initial_capital      = 10000,
         default_qty_type     = strategy.cash,
         default_qty_value    = 100,
         commission_type      = strategy.commission.percent,
         commission_value     = 0.05,
         slippage             = 2)

// ══════════════════════════════════════════════════════
//  PARAMÈTRES
// ══════════════════════════════════════════════════════
var string G_HMA  = "━━ Hull Moving Averages ━━"
var string G_RISK = "━━ Gestion du risque ━━"
var string G_DIR  = "━━ Direction ━━"

// HMA
hma1_len  = input.int  (20,    "HMA 1 (période)",               group=G_HMA,  minval=2)
hma2_len  = input.int  (50,    "HMA 2 (période)",               group=G_HMA,  minval=2)
use_hma1  = input.bool (true,  "Activer HMA 1",                 group=G_HMA)
use_hma2  = input.bool (true,  "Activer HMA 2",                 group=G_HMA)

// Risque & filtres
atr_len      = input.int  (10,    "ATR (période)",                     group=G_RISK, minval=1)
atr_filt     = input.float(0.5,   "Filtre ATR minimum (× ATR)",        group=G_RISK, step=0.1,  minval=0.0)
risk_pct     = input.float(1.0,   "Risque unitaire (% equity)",        group=G_RISK, step=0.1,  minval=0.01)
compound     = input.bool (true,  "Compound (réinvestissement)",        group=G_RISK)
slip_pts     = input.float(0.0,   "Slippage estimé (points prix)",     group=G_RISK, step=0.0001, minval=0.0)
dd_max_pct   = input.float(15.0,  "DD Maximum (%)",                    group=G_RISK, step=0.5,  minval=1.0, maxval=100.0)
cap_mult     = input.float(2.0,   "Plafond capital (×)",               group=G_RISK, step=0.5,  minval=1.1)

// Direction
allow_long  = input.bool(true, "Activer LONGS",  group=G_DIR)
allow_short = input.bool(true, "Activer SHORTS", group=G_DIR)

// ══════════════════════════════════════════════════════
//  HULL MOVING AVERAGE
//  HMA(n) = WMA( 2×WMA(n/2) − WMA(n), √n )
// ══════════════════════════════════════════════════════
hma(src, len) =>
    h = math.round(len / 2)
    s = math.round(math.sqrt(float(len)))
    ta.wma(2.0 * ta.wma(src, h) - ta.wma(src, len), s)

h1 = hma(close, hma1_len)
h2 = hma(close, hma2_len)

// ══════════════════════════════════════════════════════
//  ATR
// ══════════════════════════════════════════════════════
atr_val = ta.atr(atr_len)

// ══════════════════════════════════════════════════════
//  SIGNAUX
// ══════════════════════════════════════════════════════
cross_up_1 = use_hma1 and ta.crossover (close, h1)
cross_up_2 = use_hma2 and ta.crossover (close, h2)
long_sig   = allow_long  and (cross_up_1 or cross_up_2)

cross_dn_1 = use_hma1 and ta.crossunder(close, h1)
cross_dn_2 = use_hma2 and ta.crossunder(close, h2)
short_sig  = allow_short and (cross_dn_1 or cross_dn_2)

hma_long  = cross_up_1 ? h1 : h2
hma_short = cross_dn_1 ? h1 : h2

// ══════════════════════════════════════════════════════
//  ENTRÉE / SL / TP
// ══════════════════════════════════════════════════════
// LONG
entry_l = hma_long
sl_l    = low
dist_l  = entry_l - sl_l
tp_l    = entry_l + dist_l + slip_pts   // 1:1 net après slippage

// SHORT
entry_s = hma_short
sl_s    = high
dist_s  = sl_s - entry_s
tp_s    = entry_s - dist_s - slip_pts

// Filtre ATR
long_ok  = long_sig  and (dist_l > atr_filt * atr_val) and (dist_l > 0.0)
short_ok = short_sig and (dist_s > atr_filt * atr_val) and (dist_s > 0.0)

// ══════════════════════════════════════════════════════
//  GESTION DU CAPITAL
//  ┌─ DD MAX 15%  → STOP trading si perte depuis pic > seuil
//  └─ PLAFOND ×2  → NOUVEAU DÉPART (reset Labouchère + pic)
// ══════════════════════════════════════════════════════
var float peak_equity    = strategy.initial_capital
var float capital_floor  = strategy.initial_capital          // base du cycle en cours
var float capital_target = strategy.initial_capital * cap_mult
var bool  trading_on     = true
var int   cycle_count    = 0

// Mise à jour du pic
peak_equity := math.max(peak_equity, strategy.equity)

// Calcul drawdown depuis le pic du cycle
dd_cur = (peak_equity - strategy.equity) / peak_equity * 100.0

// ── DD MAX atteint ──
if trading_on and dd_cur >= dd_max_pct
    strategy.close_all(comment="🛑 DD MAX " + str.tostring(dd_cur, "#.#") + "%")
    trading_on := false

// ══════════════════════════════════════════════════════
//  LABOUCHÈRE INVERSÉE  [1-1-1-1]  COMPOUND
// ══════════════════════════════════════════════════════
var float[] seq      = array.from(1.0, 1.0, 1.0, 1.0)
var int     closed_n = 0

f_reset_lab() =>
    array.clear(seq)
    array.push(seq, 1.0), array.push(seq, 1.0)
    array.push(seq, 1.0), array.push(seq, 1.0)

f_bet() =>
    n = array.size(seq)
    n <= 0 ? 2.0 : n == 1 ? array.get(seq, 0) : array.get(seq, 0) + array.get(seq, n - 1)

f_update(won, bet) =>
    if won
        array.push(seq, bet)
    else
        n = array.size(seq)
        if n >= 2
            array.remove(seq, 0)
            array.remove(seq, array.size(seq) - 1)
        if array.size(seq) == 0
            f_reset_lab()

// ── PLAFOND ×CAP_MULT atteint → Nouveau départ ──
if trading_on and strategy.equity >= capital_target
    strategy.close_all(comment="🏆 CYCLE ×" + str.tostring(cap_mult) + " → RESET")
    f_reset_lab()
    capital_floor  := strategy.equity
    capital_target := strategy.equity * cap_mult
    peak_equity    := strategy.equity   // DD repart de zéro
    trading_on     := true
    cycle_count    += 1

// Détecter clôture de trade
if strategy.closedtrades > closed_n
    pnl  = strategy.closedtrades.profit(strategy.closedtrades - 1)
    bet  = f_bet()
    f_update(pnl > 0.0, bet)
    closed_n := strategy.closedtrades

// Taille de position
f_qty(sl_dist) =>
    bet  = f_bet()
    base = compound ? strategy.equity : capital_floor
    risk = bet * base * risk_pct / 100.0
    math.max(risk / sl_dist, 0.0)

// ══════════════════════════════════════════════════════
//  GESTION DES POSITIONS
// ══════════════════════════════════════════════════════
// SL mémorisé au moment du signal (bas de la bougie de croisement)
var float active_sl = na

if trading_on
    // LONG — ordre marché, exécution à l'ouverture de la bougie suivante
    if long_ok and strategy.position_size == 0
        strategy.entry("Long", strategy.long, qty=f_qty(dist_l),
             comment="▲ HMA" + str.tostring(cross_up_1 ? hma1_len : hma2_len))
        active_sl := sl_l   // SL = bas de la bougie de croisement

    // SHORT — conditions inversées
    if short_ok and strategy.position_size == 0
        strategy.entry("Short", strategy.short, qty=f_qty(dist_s),
             comment="▼ HMA" + str.tostring(cross_dn_1 ? hma1_len : hma2_len))
        active_sl := sl_s   // SL = haut de la bougie de croisement

// Sorties SL + TP calculés depuis le prix d'entrée RÉEL après fill
if strategy.position_size > 0 and not na(active_sl)
    ep  = strategy.opentrades.entry_price(0)
    atp = ep + (ep - active_sl) + slip_pts   // TP 1:1 + compensation slippage
    strategy.exit("L-Exit", "Long",  stop=active_sl, limit=atp)

if strategy.position_size < 0 and not na(active_sl)
    ep  = strategy.opentrades.entry_price(0)
    atp = ep - (active_sl - ep) - slip_pts   // TP 1:1 + compensation slippage
    strategy.exit("S-Exit", "Short", stop=active_sl, limit=atp)

// ══════════════════════════════════════════════════════
//  AFFICHAGE GRAPHIQUE
// ══════════════════════════════════════════════════════
plot(h1, "HMA " + str.tostring(hma1_len), color=color.new(color.blue,   0), linewidth=2)
plot(h2, "HMA " + str.tostring(hma2_len), color=color.new(color.orange, 0), linewidth=2)

plotshape(long_ok  and trading_on, "Long ✓",  shape.triangleup,   location.belowbar, color.new(color.lime, 0),  size=size.small)
plotshape(short_ok and trading_on, "Short ✓", shape.triangledown, location.abovebar, color.new(color.red,  0),  size=size.small)
plotshape(long_sig  and not long_ok,  "Long ✗",  shape.xcross, location.belowbar, color.new(color.gray, 40), size=size.tiny)
plotshape(short_sig and not short_ok, "Short ✗", shape.xcross, location.abovebar, color.new(color.gray, 40), size=size.tiny)

// Signal bloqué par DD ou pause
plotshape(not trading_on and (long_sig or short_sig), "Bloqué 🛑",
     shape.square, location.abovebar, color.new(color.red, 30), size=size.tiny)

// SL actif
plot(strategy.position_size != 0 ? active_sl : na, "SL",
     color=color.new(color.red,  0), style=plot.style_linebr, linewidth=1)

// TP dynamique (recalculé à chaque barre depuis l'entrée réelle)
dyn_tp = strategy.position_size > 0 and not na(active_sl)
     ? strategy.opentrades.entry_price(0) + (strategy.opentrades.entry_price(0) - active_sl) + slip_pts
     : strategy.position_size < 0 and not na(active_sl)
     ? strategy.opentrades.entry_price(0) - (active_sl - strategy.opentrades.entry_price(0)) - slip_pts
     : na
plot(dyn_tp, "TP", color=color.new(color.lime, 0), style=plot.style_linebr, linewidth=1)

// Ligne DD max (niveau plancher de sécurité)
dd_floor_price = na   // pas de sens sur le graphique prix — géré dans le tableau

// ══════════════════════════════════════════════════════
//  TABLEAU LABOUCHÈRE + CAPITAL CONTROL
// ══════════════════════════════════════════════════════
var table t = table.new(position.top_right, 2, 11,
     bgcolor      = color.new(color.black, 72),
     border_color = color.new(color.gray,  50), border_width = 1,
     frame_color  = color.new(color.gray,  50), frame_width  = 1)

// Séquence Labouchère en string
seq_str = ""
for i = 0 to array.size(seq) - 1
    seq_str += str.tostring(math.round(array.get(seq, i) * 100) / 100.0)
    if i < array.size(seq) - 1
        seq_str += "-"

bet_cur    = f_bet()
base_cur   = compound ? strategy.equity : capital_floor
risk_cur   = bet_cur * base_cur * risk_pct / 100.0
pnl_col    = strategy.netprofit >= 0.0 ? color.lime : color.red
dd_col     = dd_cur >= dd_max_pct * 0.8 ? color.red : dd_cur >= dd_max_pct * 0.5 ? color.orange : color.lime
state_str  = not trading_on ? "🛑 DD MAX — STOP" : strategy.equity >= capital_target * 0.95 ? "⚡ Proche ×" + str.tostring(cap_mult) : "✅ Actif (Cycle " + str.tostring(cycle_count + 1) + ")"
state_col  = not trading_on ? color.red : color.lime
win_rate   = strategy.closedtrades > 0 ? strategy.wintrades / strategy.closedtrades * 100.0 : 0.0

// En-tête
table.cell(t, 0, 0, "LABOUCHÈRE INV.",   text_color=color.white,  bgcolor=color.new(color.navy, 25), text_size=size.small, text_halign=text.align_center)
table.cell(t, 1, 0, "COMPOUND",           text_color=color.yellow, bgcolor=color.new(color.navy, 25), text_size=size.small, text_halign=text.align_center)

// Labouchère
table.cell(t, 0, 1, "Séquence",           text_color=color.silver, text_size=size.tiny)
table.cell(t, 1, 1, seq_str,              text_color=color.yellow, text_size=size.tiny)
table.cell(t, 0, 2, "Mise (units)",       text_color=color.silver, text_size=size.tiny)
table.cell(t, 1, 2, str.tostring(bet_cur, "#.##"), text_color=color.white, text_size=size.small)
table.cell(t, 0, 3, "Risque ($)",         text_color=color.silver, text_size=size.tiny)
table.cell(t, 1, 3, str.tostring(risk_cur, "#.##"), text_color=color.white, text_size=size.small)

// Capital
table.cell(t, 0, 4, "━━ Capital ━━",    text_color=color.white,  bgcolor=color.new(color.maroon, 40), text_size=size.tiny, text_halign=text.align_center)
table.cell(t, 1, 4, "━━ Contrôle ━━",  text_color=color.white,  bgcolor=color.new(color.maroon, 40), text_size=size.tiny, text_halign=text.align_center)
table.cell(t, 0, 5, "Equity",            text_color=color.silver, text_size=size.tiny)
table.cell(t, 1, 5, str.tostring(strategy.equity, "#.##"), text_color=pnl_col, text_size=size.small)
table.cell(t, 0, 6, "Net P&L",           text_color=color.silver, text_size=size.tiny)
table.cell(t, 1, 6, str.tostring(strategy.netprofit, "#.##"), text_color=pnl_col, text_size=size.small)
table.cell(t, 0, 7, "DD actuel",          text_color=color.silver, text_size=size.tiny)
table.cell(t, 1, 7, str.tostring(dd_cur, "#.##") + "% / " + str.tostring(dd_max_pct) + "%", text_color=dd_col, text_size=size.small)
table.cell(t, 0, 8, "Objectif ×" + str.tostring(cap_mult), text_color=color.silver, text_size=size.tiny)
table.cell(t, 1, 8, str.tostring(capital_target, "#.##"), text_color=color.aqua, text_size=size.small)
table.cell(t, 0, 9, "Cycles complétés", text_color=color.silver, text_size=size.tiny)
table.cell(t, 1, 9, str.tostring(cycle_count) + "  |  WR: " + str.tostring(win_rate, "#.#") + "%", text_color=color.white, text_size=size.small)
table.cell(t, 0, 10, "État",             text_color=color.silver, text_size=size.tiny)
table.cell(t, 1, 10, state_str,          text_color=state_col,    text_size=size.small)
